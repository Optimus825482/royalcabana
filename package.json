{
  "name": "royal-cabana-temp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"redis-server\" \"next dev -p 3006\" \"tsx socket-server/index.ts\"",
    "dev:next": "next dev -p 3006",
    "dev:socket": "tsx socket-server/index.ts",
    "build": "next build",
    "prestart": "prisma migrate deploy",
    "start": "next start -p 3006",
    "start:socket": "node --import tsx socket-server/index.ts",
    "lint": "eslint src socket-server public/sw.js next.config.ts prisma.config.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
