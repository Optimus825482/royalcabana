    "jspdf": "^4.2.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-intl": "^4.8.3",
    "nodemailer": "^7.0.13",
    "postprocessing": "^6.38.3",
