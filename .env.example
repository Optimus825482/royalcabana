# ============================================
# Royal Cabana — Coolify Environment Variables
# ============================================
# Bu değişkenleri Coolify → Service → Environment Variables'a yapıştır.
# Coolify'ın otomatik oluşturduğu SERVICE_FQDN_* değişkenlerini KULLANMIYORUZ,
# çünkü custom domain ve protokol (http/https) kontrolü lazım.

# ──────────────────────────────────────────────
# 🔒 ZORUNLU
# ──────────────────────────────────────────────
POSTGRES_PASSWORD=guclu_bir_sifre_yaz
NEXTAUTH_SECRET=openssl_rand_base64_32_ile_uret

# ──────────────────────────────────────────────
# 🌐 URL'LER (custom domain veya Coolify sslip.io)
# ──────────────────────────────────────────────
# Coolify HTTPS sağlıyorsa https:// yaz, yoksa http://
NEXTAUTH_URL=http://royalcabana.erkanerdem.net
NEXT_PUBLIC_APP_URL=http://royalcabana.erkanerdem.net
NEXT_PUBLIC_SOCKET_URL=http://socket-domain.sslip.io

# ──────────────────────────────────────────────
# 🔑 Dahili API Secret (app ↔ socket arası güvenlik)
# ──────────────────────────────────────────────
INTERNAL_API_SECRET=herhangi-bir-random-string

# ──────────────────────────────────────────────
# 🔴 Redis (rate limiting & cache)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# 🔔 Push Notifications (VAPID keys)
# ──────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@royalcabana.com

# ──────────────────────────────────────────────
# 🌱 Startup seed gate
# ──────────────────────────────────────────────
RUN_SEED_ON_STARTUP=false

# ──────────────────────────────────────────────
# 📧 SMTP (opsiyonel — email göndermek için)
# ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=uygulama-sifresi
SMTP_FROM=Royal Cabana <noreply@royalcabana.com>

# ──────────────────────────────────────────────
# ⚙️ OTOMATİK (docker-compose.yaml halleder, YAZMA)
# ──────────────────────────────────────────────
# DATABASE_URL        → compose'da postgres bağlantı string'i oluşturuyor
# AUTH_TRUST_HOST     → compose'da "true" set edilmiş
# SOCKET_INTERNAL_URL → compose'da http://socket:3007 set edilmiş
# NODE_ENV            → compose'da production set edilmiş
# HOSTNAME            → compose'da 0.0.0.0 set edilmiş
# PORT                → compose'da 3006 set edilmiş
